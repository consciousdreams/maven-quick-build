<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>it.consciousdreams.maven-quick-build</id>
    <name>MavenQuickBuild</name>
    <vendor url="https://github.com/consciousdreams/maven-quick-build">consciousdreams</vendor>
    <description>Adds configurable toolbar buttons to run Maven commands</description>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.idea.maven</depends>

    <applicationListeners>
        <listener class="it.consciousdreams.MavenActionsRegistrar"
                  topic="com.intellij.ide.AppLifecycleListener"/>
    </applicationListeners>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="it.consciousdreams.MavenQuickBuildSettings"/>
        <applicationConfigurable
            parentId="tools"
            instance="it.consciousdreams.MavenQuickBuildConfigurable"
            id="it.consciousdreams.MavenQuickBuildConfigurable"
            displayName="Maven Quick Build"/>
    </extensions>

    <actions>
        <group
            id="it.consciousdreams.MavenToolbarGroup"
            class="it.consciousdreams.MavenQuickBuildActionGroup"
            text="Maven"
            popup="false">
            <!-- New UI toolbar (2022.3+) -->
            <add-to-group group-id="MainToolbarRight" anchor="last"/>
            <!-- Legacy toolbar -->
            <add-to-group group-id="MainToolBar" anchor="last"/>
            <add-to-group group-id="NavBarToolBar" anchor="last"/>
        </group>
    </actions>
</idea-plugin>
